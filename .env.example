# Rate limiting for the public ingest proxy.
#
# The /api/ingest/* endpoints are rate-limited per client IP. With no store
# configured the limiter uses an in-memory counter — correct on a single
# long-lived server (VPS/container), but per-instance and reset on every cold
# start in serverless. On Vercel/Netlify, set Upstash Redis (REST) for a shared,
# durable counter across invocations. Create a free database at https://upstash.com.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional tuning (defaults: 30 requests per 60s window per IP).
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000
